# =============================================================================
# Line endings — Linux/macOS deploy fayllari LF bo'lishi majburiy
# =============================================================================
# Aks holda Windows'da yozilgan bash skriptlar serverda ishlamaydi
# (\r CRLF → bash "unexpected EOF" xatolari).

# Default: auto-detect
* text=auto eol=lf

# Bash / shell skriptlari — majburiy LF
*.sh        text eol=lf
*.bash      text eol=lf

# Docker va Nginx konfig fayllari — Linux serverda ishlaydi
Dockerfile            text eol=lf
*.dockerfile          text eol=lf
docker-compose*.yaml  text eol=lf
docker-compose*.yml   text eol=lf
*.conf                text eol=lf
*.conf.template       text eol=lf
*.nginx               text eol=lf

# Systemd unit fayllari — kelajak uchun
*.service   text eol=lf
*.timer     text eol=lf

# GitHub Actions workflow fayllari — har doim LF
.github/workflows/*.yml   text eol=lf
.github/workflows/*.yaml  text eol=lf

# Env misol fayllari (server'da o'qiladi)
.env.*.example  text eol=lf

# Windows-specific fayllar — CRLF qoldiring
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary fayllar
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.db        binary
*.db-wal    binary
*.db-shm    binary
*.woff2     binary
*.ttf       binary
*.otf       binary
