{
  "name": "miaoda-react-admin",
  "version": "0.0.4",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "cross-env VITE_DISABLE_MIAODA=1 vite",
    "build": "vite build && node scripts/fix-electron-dist.cjs",
    "preview": "vite preview",
    "electron:build": "tsc -p electron/tsconfig.json",
    "electron:dev": "npm run electron:build && concurrently -k \"cross-env VITE_DISABLE_MIAODA=1 vite\" \"wait-on http-get://localhost:5173/ && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:dev:with-miaoda": "npm run electron:build && concurrently -k \"vite\" \"wait-on http-get://localhost:5173/ && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:start": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win --x64",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-builder install-app-deps",
    "rebuild:electron": "npx @electron/rebuild -f -w better-sqlite3",
    "lint": "tsgo -p tsconfig.check.json; npx biome lint; .rules/check.sh; npx tailwindcss -i ./src/index.css -o NUL 2>&1 | findstr /R /C:\"^CssSyntaxError\" /C:\"^Error:\" || exit /B 0; .rules/testBuild.sh",
    "db:check": "electron electron/scripts/db-check-electron.cjs new",
    "db:reset": "electron -e \"require('./electron/scripts/db-reset.cjs')\"",
    "db:where": "electron -e \"require('./electron/scripts/db-where.cjs')\"",
    "db:check:new": "electron electron/scripts/db-check-electron.cjs new",
    "db:check:legacy": "electron electron/scripts/db-check-electron.cjs legacy",
    "db:migrate:legacy": "electron electron/scripts/db-migrate-legacy.cjs",
    "db:counts": "electron electron/scripts/db-counts.cjs",
    "db:integrity": "electron electron/scripts/db-integrity.cjs",
    "db:seed:testProducts": "electron electron/scripts/seed-test-products.cjs",
    "db:cleanup:testProducts": "electron electron/scripts/cleanup-test-products.cjs",
    "db:migrate:pieceBarcodes30": "electron electron/scripts/migrate-piece-barcodes-to-30-prefix.cjs",
    "i18n:translate": "python scripts/translate_locales.py",
    "telegram:bot": "node telegram/bot.cjs",
    "telegram:verify": "node scripts/verify-telegram-setup.cjs",
    "ngrok:rpc": "ngrok http 3333 --log=stdout",
    "ngrok:preview": "ngrok http 4173 --log=stdout",
    "ngrok:both": "node scripts/run-ngrok-both.cjs",
    "ngrok:sync-env": "node scripts/sync-ngrok-env.cjs",
    "server": "cross-env POS_SERVER_MODE=1 node electron/server.cjs",
    "server:dev": "cross-env POS_SERVER_MODE=1 POS_DATA_DIR=./.pos-data-dev node electron/server.cjs",
    "public-api": "node public-api/server.cjs",
    "public-api:dev": "cross-env POS_DATA_DIR=./.pos-data-dev node public-api/server.cjs",
    "test:public-api": "npm run test --prefix public-api",
    "mini-app:dev": "npm run dev --prefix mini-app",
    "mini-app:build": "npm run build --prefix mini-app",
    "test:agent": "node print-agent/agent.test.js",
    "test:barcode": "node src/hooks/__tests__/useBarcodeScanner.node.test.mjs",
    "test:sessions": "node electron/net/sessions.test.cjs",
    "test:hostserver": "node electron/net/hostServer.test.cjs",
    "test:authflow": "node electron/net/authFlow.test.cjs",
    "test:metrics": "node electron/net/metrics.test.cjs",
    "test:ratelimit": "node electron/net/rateLimit.test.cjs",
    "test:auditlog": "node electron/net/auditLog.test.cjs",
    "test:security": "node electron/net/security.e2e.test.cjs",
    "test:tenantRegistry": "node electron/db/tenantRegistry.test.cjs",
    "test:mtdispatch": "node electron/net/mtDispatch.test.cjs",
    "test:alertmanager": "node electron/net/alertmanagerConfig.test.cjs",
    "test:restoredrill": "node electron/net/restoreDrillConfig.test.cjs",
    "test:fail2ban": "node electron/net/fail2banAuditFilter.test.cjs",
    "test:grafana-tenants": "node electron/net/grafanaTenantsDashboard.test.cjs",
    "test:smoke": "npm run test:agent && npm run test:barcode && npm run test:sessions && npm run test:hostserver && npm run test:authflow && npm run test:metrics && npm run test:ratelimit && npm run test:auditlog && npm run test:security && npm run test:tenantRegistry && npm run test:mtdispatch && npm run test:alertmanager && npm run test:restoredrill && npm run test:fail2ban && npm run test:grafana-tenants",
    "load:warmup": "node load-test/lib/warmup.cjs",
    "load:autocannon:read": "node load-test/autocannon-rpc.cjs --scenario=read --connections=30 --duration=60",
    "load:autocannon:mixed": "node load-test/autocannon-rpc.cjs --scenario=mixed --connections=20 --duration=120",
    "load:k6:read": "k6 run load-test/k6/rpc-read.js",
    "load:k6:mixed": "k6 run load-test/k6/rpc-mixed.js",
    "load:smoke": "node load-test/autocannon-rpc.cjs --scenario=read --connections=5 --duration=10"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-query-devtools": "^5.91.1",
    "axios": "^1.13.1",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.6.1",
    "embla-carousel-react": "^8.6.0",
    "eventsource-parser": "^3.0.6",
    "fuse.js": "^7.1.0",
    "i18next": "^25.7.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "input-otp": "^1.4.2",
    "jsbarcode": "^3.12.1",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.2",
    "ky": "^1.13.0",
    "lucide-react": "^0.553.0",
    "miaoda-sc-plugin": "1.0.29",
    "next-themes": "^0.4.6",
    "node-thermal-printer": "^4.6.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "react": "^18.0.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.0.0",
    "react-dropzone": "^14.3.8",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.66.0",
    "react-i18next": "^16.4.0",
    "react-resizable-panels": "^2.1.8",
    "react-router": "^7.9.5",
    "react-router-dom": "^7.9.5",
    "react-to-print": "^3.2.0",
    "recharts": "^2.15.3",
    "sonner": "^2.0.7",
    "streamdown": "^1.4.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "video-react": "^0.16.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.4",
    "@electron/rebuild": "^4.0.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/lodash": "^4.17.20",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/uuid": "^10.0.0",
    "@types/video-react": "^0.15.8",
    "@types/xlsx": "^0.0.35",
    "@typescript/native-preview": "7.0.0-dev.20251103.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autocannon": "^8.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "depcheck": "^1.4.7",
    "electron": "^32.2.2",
    "electron-builder": "^24.13.3",
    "miaoda-sc-plugin": "^1.0.4",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.11",
    "telegraf": "^4.16.3",
    "typescript": "~5.9.3",
    "uuid": "^10.0.0",
    "vite": "^5.4.21",
    "vite-plugin-svgr": "^4.5.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.pos.tizimi.app",
    "productName": "POS Tizimi",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "node_modules/**/*",
      "electron/**/*"
    ],
    "extraFiles": [
      {
        "from": "electron/db/migrations",
        "to": "electron/db/migrations",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "POS Tizimi"
    }
  }
}
