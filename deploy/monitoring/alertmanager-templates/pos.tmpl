{{/*
  ============================================================================
  POS alert templates for Alertmanager (Bosqich 17)
  ----------------------------------------------------------------------------
  Two renderings:
    1. pos.telegram.message — compact HTML (Telegram parses <b>, <code>, <a>)
    2. pos.email.subject    — single-line header for MUAs
    3. pos.email.html       — structured table, safe with strict HTML clients

  Design rules:
    - Always show status (FIRING / RESOLVED) so resolved pages are recognisable
      at a glance.
    - Always include runbook link if the alert declared one.
    - Include instance + severity; skip low-value labels to reduce noise.
    - Group_interval is handled by Alertmanager — templates assume 1..N alerts.
  ============================================================================
*/}}

{{ define "pos.telegram.message" -}}
<b>{{ if eq .Status "firing" }}🚨 FIRING{{ else }}✅ RESOLVED{{ end }}</b>
  •  <b>{{ .GroupLabels.alertname }}</b>
  •  severity=<code>{{ .CommonLabels.severity }}</code>
{{ if .CommonLabels.env }}  •  env=<code>{{ .CommonLabels.env }}</code>{{ end }}

{{ range .Alerts -}}
─────────────
<b>{{ .Labels.alertname }}</b>{{ if .Labels.instance }} @ <code>{{ .Labels.instance }}</code>{{ end }}
{{ if .Annotations.summary }}<i>{{ .Annotations.summary }}</i>
{{ end -}}
{{ if .Annotations.description }}{{ .Annotations.description }}
{{ end -}}
{{ if .Annotations.runbook }}📘 <a href="{{ .Annotations.runbook }}">runbook</a>
{{ end -}}
🕒 started {{ .StartsAt.Format "2006-01-02 15:04 MST" }}
{{ end -}}
{{ end }}


{{ define "pos.email.subject" -}}
[POS]{{ if eq .Status "resolved" }} RESOLVED:{{ else }} {{ toUpper .CommonLabels.severity }}:{{ end }} {{ .GroupLabels.alertname }} ({{ len .Alerts }})
{{- end }}


{{ define "pos.email.html" -}}
<!doctype html>
<html>
  <head>
    <meta charset="utf-8">
    <title>POS alert</title>
    <style>
      body { font-family: -apple-system, Segoe UI, Arial, sans-serif; color: #222; }
      .banner { padding: 12px 16px; color: #fff; font-weight: bold; font-size: 18px; border-radius: 4px; }
      .firing   { background: #c62828; }
      .resolved { background: #2e7d32; }
      table { border-collapse: collapse; margin-top: 16px; width: 100%; }
      th, td { padding: 8px 12px; border: 1px solid #ddd; text-align: left; vertical-align: top; }
      th { background: #f5f5f5; width: 140px; }
      code { background: #f0f0f0; padding: 1px 4px; border-radius: 3px; }
      .muted { color: #888; font-size: 12px; }
    </style>
  </head>
  <body>
    <div class="banner {{ if eq .Status "firing" }}firing{{ else }}resolved{{ end }}">
      {{ if eq .Status "firing" }}🚨 FIRING{{ else }}✅ RESOLVED{{ end }} — {{ .GroupLabels.alertname }}
      <span style="float:right; font-size:14px;">{{ len .Alerts }} alert{{ if ne (len .Alerts) 1 }}s{{ end }}</span>
    </div>

    {{ range .Alerts }}
    <table>
      <tr><th>Instance</th>   <td><code>{{ .Labels.instance }}</code></td></tr>
      <tr><th>Severity</th>   <td>{{ .Labels.severity }}</td></tr>
      {{ if .Labels.tenant }}<tr><th>Tenant</th> <td><code>{{ .Labels.tenant }}</code></td></tr>{{ end }}
      {{ if .Annotations.summary }}     <tr><th>Summary</th>     <td>{{ .Annotations.summary }}</td></tr>{{ end }}
      {{ if .Annotations.description }} <tr><th>Description</th> <td><pre style="white-space:pre-wrap;margin:0">{{ .Annotations.description }}</pre></td></tr>{{ end }}
      {{ if .Annotations.runbook }}     <tr><th>Runbook</th>     <td><a href="{{ .Annotations.runbook }}">{{ .Annotations.runbook }}</a></td></tr>{{ end }}
      <tr><th>Started</th>  <td>{{ .StartsAt.Format "2006-01-02 15:04:05 MST" }}</td></tr>
      {{ if eq .Status "resolved" }}<tr><th>Resolved</th> <td>{{ .EndsAt.Format "2006-01-02 15:04:05 MST" }}</td></tr>{{ end }}
    </table>
    {{ end }}

    <p class="muted">
      Sent by Alertmanager{{ if .ExternalURL }} — <a href="{{ .ExternalURL }}">UI</a>{{ end }}.
      Silence: visit Alertmanager UI → &ldquo;Silences&rdquo; or run
      <code>amtool silence add alertname=&quot;{{ .GroupLabels.alertname }}&quot; --duration=1h --comment=&quot;...&quot;</code>.
    </p>
  </body>
</html>
{{- end }}
