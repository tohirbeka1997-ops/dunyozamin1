{
  "annotations": { "list": [] },
  "description": "Multi-tenant POS (Bosqich 15+): per-tenant SQLite size and RPC throughput from Prometheus. Metrics exist only when POS_MULTI_TENANT=1; single-tenant installs show empty variables.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "POS — Overview",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/pos-overview/pos-overview",
      "targetBlank": false
    }
  ],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["pos", "multi-tenant"],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "hide": 0,
        "includeAll": true,
        "label": "Tenant",
        "multi": true,
        "name": "tenant",
        "options": [],
        "query": "label_values(pos_tenant_db_size_bytes, tenant)",
        "refresh": 1,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "POS — Tenants",
  "uid": "pos-tenants",
  "version": 1,
  "panels": [
    {
      "type": "row",
      "title": "Fleet",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Active tenants",
      "description": "pos_tenants_total{state=\"active\"} — master DB catalog.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(pos_tenants_total{state=\"active\"})", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Disabled tenants",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(pos_tenants_total{state=\"disabled\"})", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        }
      },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Total tenant DB bytes (all files)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(pos_tenant_db_size_bytes)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "colorMode": "none", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Selected tenant(s) — DB bytes",
      "description": "Sum of pos_tenant_db_size_bytes for the Tenant variable.",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(pos_tenant_db_size_bytes{tenant=~\"$tenant\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "colorMode": "none", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "bargauge",
      "title": "SQLite file size by tenant",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pos_tenant_db_size_bytes",
          "legendFormat": "{{tenant}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1073741824 }, { "color": "red", "value": 2147483648 }] }
        }
      },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true }
    },
    {
      "type": "row",
      "title": "RPC (per-tenant counter)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "RPC rate by outcome — selected tenant(s)",
      "description": "pos_tenant_rpc_calls_total — incremented in mtDispatch for tenant-scoped RPCs (not master-admin channels).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 20,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(pos_tenant_rpc_calls_total{tenant=~\"$tenant\"}[$__rate_interval]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "type": "timeseries",
      "title": "Top tenants by RPC rate",
      "description": "Which stores drive load right now — independent of the Tenant filter.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 21,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(12, sum by (tenant) (rate(pos_tenant_rpc_calls_total[$__rate_interval])))",
          "legendFormat": "{{tenant}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "type": "timeseries",
      "title": "Error + denied share (selected tenant(s))",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "id": 22,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(pos_tenant_rpc_calls_total{tenant=~\"$tenant\",outcome=~\"error|denied\"}[$__rate_interval]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "type": "timeseries",
      "title": "RPC rate per tenant (stacked, top 8)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "id": 23,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(8, sum by (tenant) (rate(pos_tenant_rpc_calls_total{outcome=\"ok\"}[$__rate_interval])))",
          "legendFormat": "{{tenant}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "stacking": { "mode": "normal", "group": "A" }, "fillOpacity": 35 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    }
  ]
}
