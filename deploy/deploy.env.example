# Web deploy: nusxa deploy.env → deploy/deploy.env (gitga tushmaydi)
# yoki ildizdagi .env da DEPLOY_SERVER qatorlarini qo‘shing.

# SSH (majburiy deploy:web uchun)
DEPLOY_SERVER=user@your-server.com

# Maxfiy kalit (bo‘shliqli yo‘l uchun SSH_OPTS emas, shu ishlating)
# Windows: SSH_IDENTITY_FILE=%USERPROFILE%/.ssh/hetzner_pos
# yoki: SSH_IDENTITY_FILE=C:/Users/You/.ssh/id_ed25519
SSH_IDENTITY_FILE=

# Qo‘shimcha: port, StrictHostKeyChecking=accept-new va hokazo
# SSH_OPTS=-p 22 -o StrictHostKeyChecking=accept-new

# Serverdagi web root (default: /var/www/pos) — POS admin SPA (`deploy:web`)
REMOTE_PATH=/var/www/pos

# Telegram Mini App (mini-app/) — alohida deploy: `npm run deploy:mini-app`
# (Nginx odatda: root /opt/pos/mini-app/dist; `deploy:web` buni yubormaydi)
# MINI_APP_REMOTE_PATH=/opt/pos/mini-app/dist
# MINI_APP_RELEASES_DIR=/opt/pos/mini-app-releases
# Bir domen bo'lsa: bo'sh qoldiring. Alohida API: DEPLOY_MINI_APP_VITE_PUBLIC_API_URL=https://api.example.com

# Build va RPC (bo‘lmasa .env dagi VITE_POS_RPC_URL / VITE_POS_RPC_SECRET ishlatiladi)
# DEPLOY_API_URL=https://api.example.com
# DEPLOY_API_SECRET=serverdagi_POS_HOST_SECRET_bilan_bir_xil

# ------------------------------------------
# Server deploy (npm run deploy:server)
# ------------------------------------------
# Serverdagi loyiha katalogi (default: /opt/pos)
# DEPLOY_APP_PATH=/opt/pos
#
# Healthcheck URL (default: http://127.0.0.1:3334/health)
# DEPLOY_HEALTH_URL=http://127.0.0.1:3334/health
#
# Deploydan keyin restart qilinadigan xizmatlar (space yoki comma bilan).
# deploy-server.cjs default: public-api + telegram-bot + pos-rpc (HTTP RPC :3333).
# Docker compose ham 3333 ni ochsa — systemd pos-rpc bilan ikkalasi bir vaqtda ishlamasin (EADDRINUSE).
# Faqat public-api + bot kerak bo‘lsa:
# DEPLOY_RESTART_SERVICES=public-api.service telegram-bot.service
#
# Masofada RPC health (3333) tekshiruvi (Docker yo‘q RPC bo‘lsa — OK; bo‘lmasa WARN):
# DEPLOY_RPC_HEALTH_URL=http://127.0.0.1:3333/health
# DEPLOY_SKIP_RPC_HEALTH=1
#
# O‘rnatish/rebuild bayroqlari:
# default: root=1 (telegram runtime uchun), public-api=1
# DEPLOY_INSTALL_ROOT=1
# DEPLOY_INSTALL_PUBLIC_API=1
# DEPLOY_REBUILD_ROOT_NATIVE=1
# DEPLOY_REBUILD_PUBLIC_API_NATIVE=1
#
# Local precheckni o‘tkazib yuborish (default: 0)
# SKIP_DEPLOY_CHECKS=0
