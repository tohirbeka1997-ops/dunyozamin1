; =============================================================================
; rclone config — off-site backup target
; =============================================================================
; Copy to /opt/pos/deploy/backup/rclone.conf  (chmod 0600, owner = deploy user)
; and fill in exactly ONE remote below (delete the others).
;
; Quick start:
;   cp rclone.conf.example rclone.conf
;   chmod 0600 rclone.conf
;   rclone --config=rclone.conf lsd offsite:       # verify connectivity
;
; Default backup flow expects a remote named `offsite` and a bucket/folder
; pointed to by POS_BACKUP_REMOTE_PATH (see .env.server.example).
; =============================================================================

; --- Backblaze B2 (cheapest for cold backups; recommended default) ----------
; Create an application key scoped to ONE bucket; paste the keyId as
; `account` and the applicationKey as `key`. See https://www.backblaze.com/b2
;
; [offsite]
; type = b2
; account = 00112233aabbccdd
; key = K001xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
; hard_delete = false          ; keep B2 file versions (cheap extra safety)
; versions = false

; --- AWS S3 (or any S3-compatible: Wasabi, MinIO, Cloudflare R2) ------------
;
; [offsite]
; type = s3
; provider = AWS               ; AWS | Wasabi | Cloudflare | Minio | Other
; access_key_id = AKIA...
; secret_access_key = ...
; region = eu-central-1
; endpoint =                   ; leave empty for AWS; set for R2/Wasabi/MinIO
; storage_class = STANDARD_IA  ; cheaper tier, fine for backups
; server_side_encryption = AES256

; --- Hetzner Object Storage (S3-compatible) ---------------------------------
;
; [offsite]
; type = s3
; provider = Other
; access_key_id = ...
; secret_access_key = ...
; endpoint = https://fsn1.your-objectstorage.com
; region = fsn1
; acl = private
