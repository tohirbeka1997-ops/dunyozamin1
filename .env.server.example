# ============================================================================
# POS SERVER MODE — Hetzner / Linux VPS uchun ENV misolida
# ============================================================================
# Foydalanish:
#   cp .env.server.example .env
#   node -e "console.log(require('crypto').randomUUID())"   # POS_HOST_SECRET uchun
#   npm run server
#
# Eslatma: Hozirgi Electron rejimi ham ishlashda davom etadi — bu ENV'lar faqat
# `npm run server` chaqirilganida ishlatiladi.
# ============================================================================

# --- Server ishga tushishini yoqadi (majburiy) ---------------------------------
POS_SERVER_MODE=1

# --- Ma'lumotlar katalogi ------------------------------------------------------
# SQLite DB, config, backups, logs shu yerda saqlanadi.
# Production: /var/lib/pos  (systemd user yozish huquqi bo'lishi kerak)
POS_DATA_DIR=/var/lib/pos

# --- HTTP binding -------------------------------------------------------------
# Reverse proxy (Nginx) ortida: 127.0.0.1
# To'g'ridan-to'g'ri internet: 0.0.0.0
POS_HOST_BIND=127.0.0.1
POS_HOST_PORT=3333

# --- Bearer token (MAJBURIY, kamida 16 belgi) ---------------------------------
# Generatsiya qilish:
#   node -e "console.log(require('crypto').randomUUID())"
# Xavfsiz joyda saqlang, Git'ga kommit QILMANG.
#
# ROLI:
#   - Bootstrap / admin kalit. Faqat quyidagi holatlarda ishlatiladi:
#       * frontend `pos:auth:login`  (session token olish uchun)
#       * CLI / migratsiya skriptlari (to'liq huquq)
#       * `pos:database:*`, `pos:settings:resetDatabase` (faqat admin-bypass)
#   - Oddiy kassir/menejer esa login qilganidan keyin `pos:auth:login` qaytargan
#     SESSION TOKEN'ini ishlatadi (`Authorization: Bearer <session-token>`).
POS_HOST_SECRET=REPLACE_WITH_A_SECURE_RANDOM_UUID

# --- CORS allowlist -----------------------------------------------------------
# Bo'sh qoldirsangiz — '*' (hamma origin'larga ruxsat). Production'da aniq
# domenlarni kiriting, vergul bilan ajrating.
# Lokal Vite (npm run dev) + SSH tunnel: http://localhost:5173 qo'shing.
POS_CORS_ORIGINS=http://localhost:5173,https://app.example.com,https://admin.example.com

# --- Auto backup (local SQLite snapshots) -------------------------------------
POS_BACKUP_ENABLED=1
POS_BACKUP_INTERVAL_MIN=30
POS_BACKUP_MAX=48

# --- Off-site backup (rclone → S3 / B2 / Hetzner / Wasabi / R2) ---------------
# Destination path inside the configured rclone remote. Example:
#   B2 bucket:          offsite:my-pos-backups/prod
#   S3 bucket+prefix:   offsite:my-pos-backups/prod
# rclone config file: /opt/pos/deploy/backup/rclone.conf (see rclone.conf.example)
POS_BACKUP_REMOTE=offsite
POS_BACKUP_REMOTE_PATH=pos-backups/prod

# Off-site retention window. Files older than this on the remote will be
# deleted by the sync script (AFTER verifying newer files uploaded OK).
POS_BACKUP_REMOTE_RETENTION_DAYS=30

# Alert threshold — Prometheus alert `PosBackupStale` fires when the newest
# local backup is older than this (seconds). Default: 2h.
POS_BACKUP_LOCAL_MAX_AGE_SEC=7200

# Alert threshold — off-site sync must succeed at least this often. Default: 36h.
POS_BACKUP_OFFSITE_MAX_AGE_SEC=129600

# --- Load testing (local/staging only — DO NOT set these in prod) -------------
# Used by load-test/lib/warmup.cjs and the k6/autocannon scripts. The warmup
# helper creates a dedicated `loadtest_cashier` user if it doesn't exist; pick
# a password that nobody reuses elsewhere.
#   LOAD_TARGET=http://127.0.0.1:3333
#   LOAD_CASHIER_USER=loadtest_cashier
#   LOAD_CASHIER_PASS=LoadTest123!
#   LOAD_MIN_PRODUCTS=10

# --- Metrics / monitoring -----------------------------------------------------
# /metrics endpoint (Prometheus format) ALWAYS available via loopback. Remote
# scrapes require Authorization: Bearer <POS_METRICS_SECRET>. If unset,
# POS_HOST_SECRET is reused (OK for private networks, not ideal for public).
# Generate a separate value so you can rotate the metrics secret without
# invalidating all sessions:
#   node -e "console.log(require('crypto').randomUUID())"
POS_METRICS_SECRET=REPLACE_WITH_A_SECURE_RANDOM_UUID

# ============================================================================
# Alertmanager (Bosqich 17) — Prometheus alertlarini Telegram + email orqali
# ============================================================================
# Monitoring stack (docker-compose.monitoring.yaml) `alertmanager` servisi
# ishga tushganda quyidagilarni o'qiydi. Faqat `--profile monitoring` bilan
# kerak, aks holda bu bo'limni to'lig'icha qoldirib o'tish mumkin (compose
# `:?required` bilan ogohlantiradi).
#
# ----------------------------------------------------------------------------
# Grafana (mavjud edi, Alertmanager bilan bitta joyda ko'rinish uchun shu
# yerga ko'chirildi):
# ----------------------------------------------------------------------------
# Dastlabki Grafana admin kirishi. Birinchi kirishdan keyin Grafana UI orqali
# yangi parol qo'ying va bu qiymatni .env'dan olib tashlang (yoki secret
# manager'ga o'tkazing).
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=CHANGE_ME_min_12_chars
# Public URL — nginx /grafana/ subpath bilan ishlatilsa: https://pos.example.com/grafana
GF_ROOT_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Telegram bot (primary on-call channel)
# ----------------------------------------------------------------------------
# 1) @BotFather orqali bot yarating, token nusxasini oling.
# 2) Botni ops guruhiga admin sifatida qo'shing.
# 3) Chat ID ni oling:
#      curl "https://api.telegram.org/bot$TELEGRAM_ALERT_BOT_TOKEN/getUpdates"
#    Guruh uchun chat_id manfiy butun son bo'ladi (masalan -1001234567890).
#
# MUHIM: bot tokenini GIT'ga commit qilmang — Alertmanager konteyneri uni
# envsubst orqali YAML'ga inject qiladi, xost faylida ochiq bo'lmaydi.
TELEGRAM_ALERT_BOT_TOKEN=1234567890:AAAA_REPLACE_WITH_BOTFATHER_TOKEN
TELEGRAM_ALERT_CHAT_ID=-1001234567890

# ----------------------------------------------------------------------------
# SMTP (secondary / audit trail — required for severity=page)
# ----------------------------------------------------------------------------
# Tavsiya: dedicated alert account (masalan Gmail app password yoki
# Amazon SES). Asosiy hisob login'i emas — ruxsatlar minimal bo'lsin.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=pos-alerts@example.com
SMTP_USERNAME=pos-alerts@example.com
SMTP_PASSWORD=REPLACE_WITH_APP_PASSWORD
# EHLO/HELO — ba'zi SMTP server'lar yuboruvchi domen bilan mos kelishni talab qiladi.
SMTP_HELLO=pos.example.com
# Kim xabar oladi. Bir nechta manzil: vergul bilan ajrating.
ALERT_EMAIL_TO=oncall@example.com

# Alertmanager UI tashqi URL (silence yaratish uchun havolalar shu URL'da).
# Nginx ortida: https://pos.example.com/alertmanager
ALERTMANAGER_EXTERNAL_URL=http://localhost:9093

# ============================================================================
# Security layer (Bosqich 14) — rate limiting, audit log, proxy trust
# ============================================================================
# Nginx (or any reverse proxy) terminates TLS in front of pos-server. When
# `POS_TRUST_PROXY=1`, the server treats the first IP in X-Forwarded-For as
# the real client — critical for correct per-IP rate limiting and audit
# attribution. NEVER enable this if pos-server is exposed directly to the
# internet (bypass risk: any client could spoof XFF).
POS_TRUST_PROXY=1

# --- Rate limiting -----------------------------------------------------------
# Per-IP global /rpc budget. Defaults: 600 requests per 60s. For a typical
# 10-30 terminal fleet this is comfortably above normal traffic; raise only
# after you've observed sustained throttling in `pos_rate_limit_blocked_total`.
POS_RATE_LIMIT_RPC_WINDOW_MS=60000
POS_RATE_LIMIT_RPC_MAX=600

# Per-(IP, username) login budget. Defaults: 10 tries per 15 minutes. Credit
# stuffing / password spraying is throttled independently of read traffic.
POS_RATE_LIMIT_LOGIN_WINDOW_MS=900000
POS_RATE_LIMIT_LOGIN_MAX=10

# --- Audit log ---------------------------------------------------------------
# Append-only JSONL of auth events, permission denials, rate-limit blocks and
# dangerous RPCs. Rotated by logrotate (see deploy/security/pos-audit.logrotate).
# If unset, defaults to $POS_DATA_DIR/logs/audit.log.
POS_AUDIT_ENABLED=1
POS_AUDIT_LOG_PATH=/var/lib/pos/logs/audit.log
# fail2ban (7.18) audit.log'dagi `ip` maydoniga tayanadi — bu qiymat faqat
# ishonchli reverse proxy ortida `POS_TRUST_PROXY=1` bilan to'g'ri bo'ladi.

# ============================================================================
# Multi-tenant mode (Bosqich 15) — har bir do'kon alohida SQLite
# ============================================================================
# Default OFF (=0). When enabled, pos-server:
#   * creates $POS_DATA_DIR/master.db (tenant catalog + super-admin users
#     + cross-tenant session store),
#   * auto-adopts any pre-existing $POS_DATA_DIR/pos.db as tenant "default"
#     on first start (old file is COPIED, not moved, until you verify),
#   * routes every /rpc call through the tenant the caller is logged into.
#
# WARNING: flipping this flag ON/OFF mid-life isn't a trivial config change —
# session tokens issued in one mode are invalid in the other. Drain traffic,
# then restart.
POS_MULTI_TENANT=0

# Seed the first super-admin from env the FIRST time the master DB is created.
# Required to log in via `pos:master:login` (admin UI). After the first
# successful login you should create additional admins via SQL + rotate this
# bootstrap credential out. Password must be ≥ 8 characters.
POS_MASTER_ADMIN_USER=superadmin
POS_MASTER_ADMIN_PASS=CHANGE_ME_before_first_start_min_8_chars

# ============================================================================
# Frontend build (Vite) ENV'lari — shu .env'dan o'qiladi (loadRootEnv)
# ============================================================================
# HTTPS orqali reverse proxy (Nginx) ishlatilsa — bu URL public domenga ishora
# qiladi, `/rpc` avtomatik qo'shiladi.
VITE_POS_RPC_URL=https://api.example.com
# MUHIM: POS_HOST_SECRET bilan bir xil qiymat. Faqat BOOTSTRAP login uchun
# kerak. Login'dan keyin frontend sessiya token bilan ishlaydi (token
# `localStorage["pos_session_token"]` ichida, 12 soatga amal qiladi).
# HTTPS + ishonchli tarmoqda ishlating (shared secret'ni har kim ko'ra oladi).
VITE_POS_RPC_SECRET=REPLACE_WITH_A_SECURE_RANDOM_UUID
