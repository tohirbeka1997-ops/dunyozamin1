# Loyiha ildizi: nusxa .env.example → .env  (gitga commit qilinmaydi)
# Vite: `npm run dev` / `vite build` — `.env`, `.env.local`, `.env.production` ni o‘zi o‘qiydi
# Electron: `electron:*` — ildizdagi `.env` loadRootEnv orqali
# Bot: `npm run telegram:bot` — xuddi shu `.env`

# Mini App ochiladigan HTTPS sahifa (Telegram talab qiladi). Oxirida / bo‘lishi shart emas.
# Masalan production: https://app.dunyozamin.com
VITE_APP_PUBLIC_URL=

# HOST RPC (HTTPS ildiz, /rpc qo‘shmang — kod qo‘shadi). pos-config.json → host.secret bilan bir xil:
VITE_POS_RPC_URL=
VITE_POS_RPC_SECRET=

# Web deploy (npm run deploy:web). Git PATH da ssh + rsync bo‘lishi kerak (Git for Windows).
# DEPLOY_SERVER=deploy@your-vps-ip
# REMOTE_PATH=/var/www/pos

# Bot (@BotFather). TELEGRAM_WEB_APP_URL bo‘lmasa, VITE_APP_PUBLIC_URL ishlatiladi.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEB_APP_URL=
# Bot -> public-api ichki endpointlar uchun maxfiy kalit (uzun random string)
TELEGRAM_BOT_INTERNAL_SECRET=
# Bot internal API manzili (odatda local service)
# TELEGRAM_PUBLIC_API_URL=http://127.0.0.1:3334
# Broadcast (admin) uchun alohida secret
# TELEGRAM_BROADCAST_SECRET=
# Yangi buyurtma admin alertlari uchun Telegram chat_id lar (vergul bilan)
# TELEGRAM_ADMIN_IDS=123456789,987654321
# Admin status action imzosi (anti-replay) maksimal yoshi (sekund)
# TELEGRAM_ADMIN_SIGN_MAX_AGE_SEC=120
# Telegram notify retry/timeout tuning
# TELEGRAM_NOTIFY_RETRY_COUNT=3
# TELEGRAM_NOTIFY_TIMEOUT_MS=7000
# Bot rejimi: polling yoki webhook
# TELEGRAM_BOT_MODE=polling
# TELEGRAM_WEBHOOK_BASE_URL=https://app.example.com
# TELEGRAM_WEBHOOK_PATH=/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_WEBHOOK_PORT=8081

# Marketplace loyalty: har 1000 so'm to'lov uchun nechta ball
# MARKETPLACE_LOYALTY_POINTS_PER_1000=1

# VPS: SQLite katalogi (pos.db). public-api + telegram-bot. Masalan: /var/lib/pos
# POS_DATA_DIR=/var/lib/pos
#
# Public API (Telegram Mini App /v1/auth) — majburiy: kamida 16 belgi, yo‘q bo‘lsa kirish: server_misconfigured
# Batafsil: .env.server.example
# JWT_SECRET=
# JWT_REFRESH_SECRET=
# Telegram group chat ID for courier dispatch messages (bot must be in the group).
# TELEGRAM_COURIER_GROUP_ID=
# Optional bootstrap/fallback Telegram usernames allowed to use courier panel in bot (without @, comma-separated).
# Main courier registry is stored in marketplace_couriers and managed from POS/bot admin panel.
# TELEGRAM_COURIER_USERNAMES=TOHIR3

# Electron HOST CORS (ixtiyoriy, vergul bilan bir nechta origin)
# POS_RPC_CORS_ORIGINS=https://example.com,https://web.telegram.org

# Local Print Agent (kassa PC'da node agent.js orqali ishlaydi)
# Faqat web/SaaS buildda ishlatiladi; Electron desktopda e'tiborga olinmaydi.
# VITE_PRINT_AGENT_URL=http://127.0.0.1:9100
# VITE_PRINT_AGENT_SECRET=

# Multi-tenant rejim (Bosqich 16) — brauzer avtomatik ravishda `pos:health`
# javobidan multi_tenant bayrog'ini o'qiydi, shu sababli frontend'ga yangi
# VITE_* bayroq kerak EMAS. Server-side konfiguratsiya uchun
# `.env.server.example`'dagi POS_MULTI_TENANT / POS_MASTER_ADMIN_USER /
# POS_MASTER_ADMIN_PASS'ni sozlang.

# Marketplace catalog qidiruv/trending tuning
# SEARCH_PREFILTER_LIMIT=500
# TRENDING_RECENT_WEIGHT=2
# TRENDING_AVAILABILITY_BONUS=8
# TRENDING_MARGIN_DIVISOR=1000
# TRENDING_MARGIN_CAP=80
# PAYMENT_REMINDER_DELAY_MIN=5
